VITE_SUPABASE_ANON_KEY=

# Sentry — DSN do projeto CondoVote
VITE_SENTRY_DSN=https://3dc47e375bd81fe0c6b8ce201a6f716a@o4510449042325504.ingest.us.sentry.io/4510982976045056

# Sentry Auth Token — APENAS em CI/CD (Vercel secret / GitHub Actions secret)
